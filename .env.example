# Example .env file for Ansible SOHO Infrastructure
# Copy this to .env and fill in your values
# DO NOT commit .env to version control!

# Proxmox VE Configuration
PROXMOX_SERVER=proxmox.example.com
PROXMOX_USER=ansible@pve
PROXMOX_PASSWORD=your_secure_password_here

# Technitium DNS Configuration
TECHNITIUM_SERVER=dns.example.com
TECHNITIUM_API_TOKEN=your_api_token_here

# Email Configuration (for alerts)
ADMIN_EMAIL=admin@makerspace.local
SMTP_SERVER=localhost
SMTP_PORT=25

# Network Configuration
WIFI_NETWORK=192.168.1.0/24
LAB_NETWORK=192.168.2.0/24
DATACENTER_NETWORK=10.0.0.0/24

# Backup Configuration
BACKUP_SERVER=nas-01.local
BACKUP_PATH=/backups
